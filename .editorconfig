root = true

### Default

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

### Java

[*.java]
indent_style = space
indent_size = 4

### Kotlin

[*.kt]
indent_style = space
indent_size = 4

[*.kts]
indent_style = space
indent_size = 4

### Rust

[*.rs]
indent_style = space
indent_size = 4

### TypeScript / JavaScript

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = space
indent_size = 2

### JSON

[*.json]
indent_style = space
indent_size = 2

### YAML

[*.{yml,yaml}]
indent_style = space
indent_size = 2

### HTML

[*.html]
indent_style = space
indent_size = 2

### CSS

[*.css]
indent_style = space
indent_size = 2

### SCSS

[*.scss]
indent_style = space
indent_size = 2

### Markdown

[*.md]
trim_trailing_whitespace = false

### XML

[*.xml]
indent_style = space
indent_size = 4

### SQL

[*.sql]
indent_style = space
indent_size = 4

### Shell

[*.sh]
indent_style = space
indent_size = 2

### Docker

[Dockerfile]
indent_style = space
indent_size = 2

[*.dockerfile]
indent_style = space
indent_size = 2

### Nginx

[*.conf]
indent_style = space
indent_size = 4

### GitHub Actions

[.github/workflows/*.yml]
indent_style = space
indent_size = 2
